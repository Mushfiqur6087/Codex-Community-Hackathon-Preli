```dotenv
# Variable names only. Do NOT put real values here.
# Copy to `.env` and fill in locally. For deployment, set these in the
# hosting platform's environment variables (NOT in the repo).

# --- Server ---
PORT=8000

# --- LLM (optional, disabled by default) ---
# When LLM_ENABLED is not "1" or LLM_API_KEY is empty, the orchestrator
# falls back to the deterministic rule path. The rule path handles every
# public sample case in under 1ms with zero LLM cost.
#
# LLM_ENABLED=1
# LLM_API_KEY=
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini
# LLM_TIMEOUT_S=5
#
# OpenRouter example (set BASE_URL + MODEL accordingly):
#   LLM_BASE_URL=https://openrouter.ai/api/v1
#   LLM_MODEL=openai/gpt-4o-mini
#
# LLM_TIMEOUT_S=5 keeps the LLM path in the partial-credit p95 tier
# (≤5s full credit, ≤15s partial). The client is single-shot (no retry)
# so worst-case latency is one timeout. The rule path catches any miss.
```
