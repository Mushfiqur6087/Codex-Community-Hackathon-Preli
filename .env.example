```dotenv
# Variable names only. Do NOT put real values here.
# Copy to `.env` and fill in locally. For deployment, set these in the
# hosting platform's environment variables (NOT in the repo).

# --- Server ---
PORT=8000

# --- LLM via OpenRouter (https://openrouter.ai/) ---
# The LLM is mandatory in this service. If any of these are missing or
# LLM_ENABLED is not "1", the service refuses to start (LLMConfigError).
#
# LLM_ENABLED=1
# LLM_API_KEY=sk-or-v1-...
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_MODEL=openai/gpt-4o-mini
# LLM_TIMEOUT_S=5
#
# Any OpenRouter model slug works, e.g.:
#   openai/gpt-4o-mini
#   anthropic/claude-3.5-sonnet
#   google/gemini-2.0-flash-001
#   meta-llama/llama-3.1-70b-instruct
#
# OpenRouter attribution headers (optional):
#   OPENROUTER_APP_NAME=QueueStorm Investigator
#   OPENROUTER_APP_URL=https://example.com
#
# LLM_TIMEOUT_S=5 keeps the LLM path in the partial-credit p95 tier
# (rubric: ≤5s full credit, ≤15s partial). The client is single-shot
# (no retry), so worst-case latency is one timeout.
```
