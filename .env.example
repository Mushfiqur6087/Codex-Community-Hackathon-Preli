```dotenv
# Variable names only. Do NOT put real values here.
# Copy to `.env` and fill in locally if needed.

# --- Server ---
PORT=8000

# --- LLM (optional, disabled by default) ---
# When LLM_ENABLED is not "1" or LLM_API_KEY is empty, the orchestrator falls
# back to the deterministic rule path. Set LLM_ENABLED=1 to use the LLM path
# for ambiguous tickets.
#
# LLM_API_KEY=
# LLM_BASE_URL=https://api.your-llm-provider.com/v1
# LLM_MODEL=your-model-name
# LLM_TIMEOUT_S=8
# LLM_ENABLED=1
```
