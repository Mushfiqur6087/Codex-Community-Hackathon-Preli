# Variable names only. Do NOT put real values here.
# Copy to `.env` and fill in locally if needed.

# --- Server ---
PORT=8000

# --- LLM via OpenRouter (https://openrouter.ai/) ---
# Set LLM_ENABLED=1 AND a real LLM_API_KEY to enable the LLM path.
# When LLM_ENABLED is not "1" or LLM_API_KEY is empty, the orchestrator falls
# back to the deterministic rule path. Set LLM_ENABLED=1 to use the LLM path
# for ambiguous tickets.
#
# LLM_API_KEY=sk-or-v1-...
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_MODEL=openai/gpt-4o-mini
# LLM_TIMEOUT_S=20
# LLM_ENABLED=1
#
# Any OpenRouter model slug works, e.g.:
#   openai/gpt-4o-mini
#   anthropic/claude-3.5-sonnet
#   google/gemini-2.0-flash-001
#   meta-llama/llama-3.1-70b-instruct
